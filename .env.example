# GovCheck AI - Environment Variables

# Groq API Configuration for LLM
GROQ_API_KEY=your_groq_api_key_here
GROQ_GENERATOR_MODEL=llama-3.3-70b-versatile

# Embedding Model Configuration
EMBEDDING_MODEL=intfloat/multilingual-e5-base

# Directory Paths
CHROMA_PERSIST_DIR=./chroma_db
OUTPUT_DIR=./output

# Chunking / semantic chunking
CHUNK_MAX_TOKENS=512
CHUNK_OVERLAP=128
SEMANTIC_SIM_THRESHOLD=0.70
SEMANTIC_MIN_TOKENS=128

# Retrieval tuning
SEARCH_WEIGHT_ALPHA=0.7
RETRIEVAL_FETCH_MULTIPLIER=3

# Optional cross-encoder re-ranking (downloads model on first use)
RERANK_ENABLE=false
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_CANDIDATE_MULTIPLIER=2

# Verification pass (filters unsupported requirements)
VERIFY_ENABLE=true
VERIFY_MIN_CONFIDENCE=0.80
