# GovCheck AI - Environment Variables

# Groq API Configuration for LLM
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_GENERATOR_MODEL=llama-3.3-70b-versatile
PICOCLAW_API_KEY=your_picoclaw_api_key_here
PICOCLAW_AGENTIC_ENABLED=false

# Queue / worker configuration
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_MAX_TASKS_PER_CHILD=20
JOB_STATUS_TTL_SECONDS=86400

# Embedding Model Configuration
EMBEDDING_MODEL=intfloat/multilingual-e5-base

# Directory Paths
CHROMA_PERSIST_DIR=./chroma_db
OUTPUT_DIR=./output
